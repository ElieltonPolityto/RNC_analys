# Copie este arquivo para .env e preencha a chave da OpenAI.
OPENAI_API_KEY=

# Modelo padrao. Ajuste conforme sua conta e custo desejado.
OPENAI_MODEL=gpt-5.5

# Busca historica/RAG.
# local_hash = gratuito e local; huggingface = usa Hugging Face Inference API; disabled = desliga a busca vetorial.
EMBEDDING_PROVIDER=local_hash
LOCAL_EMBEDDING_DIMENSIONS=384
CHROMA_COLLECTION=

# Preencha somente se EMBEDDING_PROVIDER=huggingface.
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_EMBEDDING_URL=
